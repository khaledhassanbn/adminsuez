rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // قواعد مبسّطة: أي مستخدم مسجّل دخول يقدر يقرأ ويكتب أي مستند.
    // تم اعتمادها لإيقاف أخطاء permission-denied المتكررة في التطبيقات الثلاثة
    // (المتجر / المندوب / الأدمن) التي تشارك نفس مشروع Firebase.
    //
    // ملاحظة أمان: لتشديد الصلاحيات لاحقًا، النسخة التفصيلية محفوظة في
    // firestore.rules.detailed.bak
    // ============================================================================

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
