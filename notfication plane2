#### [MODIFY] Firestore Security Rules

```javascript
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════
    // الإعلانات — القراءة لأي مستخدم مسجل، الكتابة للأدمن فقط
    // ═══════════════════════════════════════════════════
    match /announcements/{announcementId} {
      // القراءة: أي مستخدم مسجل (لعرض مركز الرسائل)
      allow read: if request.auth != null;
      // الكتابة: الأدمن فقط (إنشاء + تحديث stats.inAppReadCount)
      allow create: if isAdmin();
      // تحديث: الأدمن يحدث كل شيء، المستخدم العادي يحدث stats.inAppReadCount فقط
      allow update: if isAdmin() || 
        (request.auth != null && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']));
    }
    
    // ═══════════════════════════════════════════════════
    // سجل الأخطاء — القراءة والكتابة للأدمن وCloud Functions فقط
    // ═══════════════════════════════════════════════════
    match /announcement_error_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // الكتابة عبر Cloud Functions فقط
    }
    
    // ═══════════════════════════════════════════════════
    // القوالب — الأدمن فقط
    // ═══════════════════════════════════════════════════
    match /announcement_templates/{templateId} {
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════
    // الإعلانات المنبثقة — القراءة لأي مستخدم، الكتابة للأدمن
    // ═══════════════════════════════════════════════════
    match /promotional_popups/{popupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════
    // سجل العمليات الإدارية — الأدمن فقط
    // ═══════════════════════════════════════════════════
    match /announcement_admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'admin';
    }
  }
}
```

